__d(function(g,r,_i,_a,m,_e,d){"use strict";function e(e){return e&&e.__esModule?e:{default:e}}Object.defineProperty(_e,'__esModule',{value:!0}),Object.defineProperty(_e,"default",{enumerable:!0,get:function(){return j}});var t=e(r(d[0])),i=r(d[1]),o=e(r(d[2])),a=r(d[3]),n=r(d[4]),l=r(d[5]),s=r(d[6]),c='manuals_data_v2',u=[{color:'#FF6600',textColor:'#fff'},{color:'#C01380',textColor:'#fff'},{color:'#003580',textColor:'#fff'},{color:'#F7C800',textColor:'#1a1a1a'},{color:'#006DBF',textColor:'#fff'},{color:'#2E7D32',textColor:'#fff'},{color:'#B71C1C',textColor:'#fff'},{color:'#4A148C',textColor:'#fff'},{color:'#E65100',textColor:'#fff'},{color:'#37474F',textColor:'#fff'}];a.UIManager.setLayoutAnimationEnabledExperimental&&a.UIManager.setLayoutAnimationEnabledExperimental(!0);var p=[{id:'easyjet',name:'easyJet',code:'EZY',color:'#FF6600',textColor:'#fff',commands:[{cmd:'L',desc:'Lista voli del giorno',category:'Flight Ops'},{cmd:'OF/[volo]',desc:'Apri volo per check-in',category:'Flight Ops'},{cmd:'CF/[volo]',desc:'Chiudi volo',category:'Flight Ops'},{cmd:'LOF',desc:'Lista voli aperti',category:'Flight Ops'},{cmd:'GC/[gate]',desc:'Cambia gate',category:'Flight Ops'},{cmd:'F[cognome]/[nome]',desc:'Cerca passeggero per nome',category:'Search'},{cmd:'.[booking ref]',desc:'Cerca per codice prenotazione',category:'Search'},{cmd:'C[n]',desc:'Check-in passeggero linea n',category:'Check-in'},{cmd:'C[n]-[m]',desc:'Check-in gruppo (linee n-m)',category:'Check-in'},{cmd:'AB[n]',desc:'Aggiungi bagaglio a passeggero',category:'Baggage'},{cmd:'.DSP[n]',desc:'Mostra/cambia seat plan',category:'Seating'},{cmd:'.SS/[volo]/[s1]-[s2]',desc:'Seat swap',category:'Seating'},{cmd:'.SAG[volo]',desc:'Lista Seat at Gate',category:'Seating'},{cmd:'DSP1',desc:'Seat plan per SAG customer 1',category:'Seating'},{cmd:'.COM[n]',desc:'Visualizza commenti booking',category:'Customer'},{cmd:'COM[n]',desc:'Aggiungi commento a booking',category:'Customer'},{cmd:'TM[n]',desc:'Cambia titolo a Male',category:'Customer'},{cmd:'TF[n]',desc:'Cambia titolo a Female',category:'Customer'},{cmd:'J[n]',desc:'Cambia titolo a Child',category:'Customer'},{cmd:'EX',desc:'Esci / logout',category:'System'}],sections:[{title:'Check-in DCS',items:[{title:'Apertura volo',body:'Accedere al DCS (opzione 16). Digitare `L` per lista voli.\n\nPer aprire il volo: `OF/[numero volo]` e confermare con Y.\n\nImpostare boarding card e bag tag su A (auto).\nInserire gate, orario boarding e capacit\xe0.\n\nVerificare:\n\u2022 Numero volo e data corretti\n\u2022 Rotta e gate assegnati\n\u2022 Segmenti collegati (connessioni)\n\u2022 Restrizioni eventuali sul volo'},{title:'Check-in passeggeri',body:'Cercare passeggero: `F[cognome]/[nome]` oppure `.[booking ref]`.\n\nCheck-in: `C[n]` per singolo, `C[n]-[m]` per gruppo.\n\nRichiedere documento d\'identit\xe0 valido.\n\nDocumenti accettati (UE):\n\u2022 Carta d\'identit\xe0\n\u2022 Passaporto\n\nVerificare: validit\xe0, nome uguale al biglietto, destinazione.\n\nAssegnare posto con `.DSP[n]`.'},{title:'Bagaglio a mano',body:'Misure max bagaglio cabina:\n\u2022 Standard: 56\xd745\xd725 cm (inclusa impugnatura e ruote)\n\u2022 Borsa aggiuntiva: 45\xd736\xd720 cm\n\nSe eccede \u2192 addebitare hold baggage fee.\nSe il volo \xe8 pieno \u2192 imbarchare gratis in stiva.'},{title:'Overbooking',body:'Procedura overbooking:\n1. Verificare numero di passeggeri in eccesso\n2. Cercare volontari (offrire voucher + volo alternativo)\n3. Se nessun volontario \u2192 denied boarding involontario\n\nAggiungere commento al booking con `COM[n]` selezionando il motivo appropriato.\n\nRegolamento EU 261/2004:\n\u2022 Voli \u22641.500 km \u2192 \u20ac250\n\u2022 Voli 1.500\u20133.500 km \u2192 \u20ac400\n\u2022 Voli >3.500 km \u2192 \u20ac600\n\nOltre a rimborso o volo alternativo.'}]},{title:'Gate e Imbarco',items:[{title:'Apertura gate',body:'Prima di aprire il gate:\n\u2022 Attivare gate nel sistema DCS\n\u2022 Per cambiare gate: `GC/[numero gate]`\n\u2022 Verificare lista SPEQ comunicata al capo cabina\n\u2022 Controllare info gate board\n\u2022 Comunicare ritardi se presenti\n\nPer lista SAG: `.SAG[numero volo]`'},{title:'Sequenza boarding',body:'Ordine imbarco easyJet:\n1. Passeggeri speciali (WCHR, WCHC, famiglie con bambini <5 anni)\n2. easyJet Plus + posti Upfront & Extra Legroom\n3. Tutti gli altri passeggeri\n\nVerificare sempre boarding pass + documento.\n\nPer seat swap operativo: `.SS/[volo]/[posto1]-[posto2]`'},{title:'Chiusura volo',body:'Procedura chiusura:\n1. Scansione ultimi passeggeri (T-15 min)\n2. Riconciliare no-show nel DCS\n3. Last-minute changes comunicati al capo volo\n4. Invio load sheet definitiva\n5. Chiusura volo: `CF/[numero volo]`\n6. Comunicare al gate supervisore\n\nPer verificare voli aperti: `LOF`'}]},{title:'Passeggeri Speciali',items:[{title:'Codici WCHR / WCHC / WCHS',body:'WCHR \u2192 pu\xf2 camminare, ha difficolt\xe0 sulle scale.\nWCHC \u2192 non pu\xf2 camminare, necessita assistenza totale.\nWCHS \u2192 non pu\xf2 fare scale (usa pontile o bus).\n\nSempre:\n\u2022 Pre-imbarcare\n\u2022 Notificare capo cabina e handling\n\u2022 Verificare posto (non uscita emergenza)'},{title:'UM \u2013 Unaccompanied Minor',body:'Minori non accompagnati (5\u201314 anni):\n\u2022 Servizio UM obbligatorio\n\u2022 Modulo UM compilato da genitore/tutore\n\u2022 Accettare solo con form completo\n\u2022 Notificare capo cabina\n\u2022 Contatti ritirante a destinazione\n\u2022 Non lasciare mai il minore da solo'},{title:'MEDA \u2013 Passeggero Medico',body:'Passeggero con condizione medica rilevante:\n\u2022 Richiede MEDA clearance pre-volo\n\u2022 MEDA form compilato dal medico curante\n\u2022 Eventuale accompagnatore medico (MEDA + 1)\n\u2022 Comunicare al Comandante\n\u2022 Equipaggiamento medico a bordo verificato'},{title:'Documenti di viaggio',body:'Verificare sempre:\n\u2022 Validit\xe0 documento (min. 3 mesi oltre la data di rientro per alcuni paesi)\n\u2022 Visto se necessario (TIMATIC nel DCS)\n\u2022 Per viaggi extra-Schengen: passaporto obbligatorio\n\u2022 APIS: inserire dati documento nel sistema se richiesto dalla rotta'}]},{title:'Tariffe Aeroportuali',items:[{title:'Bagaglio irregolare al gate',body:'Bagaglio cabina fuori misura o non conforme al gate: \u20ac58.\n\nViene imbarcato in stiva.\n\nMisure consentite:\n\u2022 Standard: 45\xd736\xd720 cm\n\u2022 Grande (Plus/Up Front/Extra Legroom): 56\xd745\xd725 cm'},{title:'Bagaglio da aggiungere',body:'Bagaglio stiva da aggiungere in aeroporto: \u20ac65.\n\nBagaglio stiva 23kg prenotato online: da \u20ac11.99 (varia per rotta/periodo).'},{title:'Sovrappeso bagaglio',body:'Bagaglio che supera il peso acquistato:\n\u2022 \u20ac15 per ogni kg in eccesso\n\u2022 Peso massimo consentito: 32kg\n\nPesare sempre il bagaglio e addebitare la differenza.'}]}]},{id:'wizzair',name:'Wizz Air',code:'W6',color:'#C01380',textColor:'#fff',sections:[{title:'Check-in DCS',items:[{title:'Apertura check-in',body:'Accedere al sistema DCS Wizz Air con credenziali personali.\n\nSelezionare il volo \u2192 verificare rotta, data e orario \u2192 avviare check-in.\n\nCheck-in online disponibile da 30 giorni a 3 ore prima del volo.'},{title:'Documenti accettati',body:'Per TUTTI i voli:\n\u2022 Passaporto valido\n\nVoli intra-Schengen (paesi selezionati):\n\u2022 Carta d\'identit\xe0\n\nVerificare sempre validit\xe0 e destinazione tramite TIMATIC.'},{title:'WIZZ Priority',body:'Passeggeri WIZZ Priority:\n\u2022 Corsia dedicata al check-in\n\u2022 Imbarco prioritario\n\u2022 Bagaglio cabina grande (40\xd730\xd720 cm + borsa)\n\u2022 Verificare tariffa Priority sulla prenotazione o Wizz+ membership\n\nSenza Priority: solo borsa piccola 40\xd730\xd720 cm.'}]},{title:'Bagaglio',items:[{title:'Politica bagagli',body:'Bagaglio incluso in tutti i biglietti:\n\u2022 1 borsa piccola 40\xd730\xd720 cm (sotto sedile) \u2013 GRATIS\n\nA pagamento (prenotato online o al banco):\n\u2022 Bagaglio cabina grande 55\xd740\xd723 cm\n\nBagaglio stiva disponibile: 10 kg / 20 kg / 26 kg / 32 kg\nVerificare la prenotazione nel DCS.'},{title:'Eccesso bagaglio al banco',body:'Se il bagaglio non \xe8 prenotato o supera i limiti:\n1. Verificare nel DCS la prenotazione bagagli\n2. Addebitare la tariffa airport fee (superiore al prezzo online)\n3. Registrare il pagamento nel sistema\n4. Emettere ricevuta\n5. Attaccare tag bagaglio correttamente'}]},{title:'Gate e Imbarco',items:[{title:'Sequenza boarding',body:'Ordine imbarco Wizz Air:\n1. Passeggeri speciali + WCHR + famiglie con bambini piccoli\n2. WIZZ Priority\n3. Tutti gli altri\n\nVerificare boarding pass (app o cartaceo) + documento d\'identit\xe0 ad ogni imbarco.'},{title:'Chiusura volo',body:'Procedura chiusura volo:\n1. Scansione ultimi passeggeri\n2. Riconciliare no-show nel sistema\n3. Bags reconcile (bagagli senza passeggero \u2192 scaricare)\n4. Trasmettere dati finali al vettore\n5. Chiudere gate nel DCS\n6. Notificare supervisore'}]},{title:'Tariffe Aeroportuali',items:[{title:'Check-in aeroportuale',body:'Check-in al banco aeroporto: \u20ac40 a passeggero.\n\nIl passeggero deve aver fatto check-in online (da 30 giorni a 3h prima). Se non l\'ha fatto, addebitare la tariffa.'},{title:'Bagaglio irregolare al gate',body:'Bagaglio cabina fuori misura o non conforme al gate: \u20ac58.\n\nViene imbarcato in stiva.\n\nMisure consentite senza Priority: 40\xd730\xd720 cm.\nCon WIZZ Priority: 55\xd740\xd723 cm inclusa.'},{title:'Bagaglio da aggiungere',body:'Bagaglio stiva da aggiungere in aeroporto: \u20ac65.\n\nBagaglio stiva disponibile online: 10kg / 20kg / 26kg / 32kg.\nVerificare sempre la prenotazione nel DCS.'},{title:'Sovrappeso bagaglio',body:'Bagaglio che supera il peso acquistato:\n\u2022 \u20ac15 per ogni kg in eccesso\n\nPesare sempre il bagaglio e addebitare la differenza.'}]}]},{id:'ryanair',name:'Ryanair',code:'FR',color:'#003580',textColor:'#fff',sections:[{title:'Check-in DCS',items:[{title:'Check-in online obbligatorio',body:'Ryanair richiede check-in online obbligatorio (2\u201330 giorni prima).\n\nAl banco: solo per casi speciali (SPEQ, documenti da verificare, bagagli).\n\nVerificare boarding pass su app Ryanair o PDF stampato.'},{title:'Priority Boarding',body:'Passeggeri con Priority:\n\u2022 Boarding prioritario\n\u2022 Bagaglio cabina grande 55\xd740\xd720 cm incluso\n\u2022 Verificare tariffa (Regular Plus, Family Plus) o Ryanair+ membership\n\nSenza Priority:\n\u2022 Solo borsa 40\xd720\xd725 cm (sotto sedile) \u2013 GRATIS\n\u2022 Bagaglio cabina non incluso'},{title:'Gestione bagagli non-Priority',body:'Se passeggero senza Priority porta bagaglio grande:\n\u2022 Al gate: imbarcare in stiva GRATIS (se volo non pieno)\n\u2022 Addebitare tariffa se supera i limiti\n\nAl banco check-in:\n\u2022 Addebitare bagaglio cabina se non incluso nel biglietto\n\u2022 Registrare nel DCS e emettere ricevuta'}]},{title:'Gate Operations',items:[{title:'Scan boarding pass',body:'Scansione boarding pass:\n\u2022 App Ryanair (QR code)\n\u2022 PDF stampato (con QR code leggibile)\n\nIn caso di errore lettura:\n1. Verificare volo e data\n2. Controllare documento d\'identit\xe0\n3. Verificare manualmente nel DCS\n4. Contattare supervisore se necessario'},{title:'Eccesso bagaglio al gate',body:'Al gate \u2013 bagaglio fuori misura:\n1. Misurare con il gauge\n2. Addebitare gate fee (tariffa pi\xf9 alta)\n3. Imbarcare in stiva\n4. Emettere ricevuta\n\nNote: il gate fee \xe8 significativamente pi\xf9 alto della tariffa online.'},{title:'Chiusura e DEP',body:'Chiusura volo Ryanair:\n\u2022 Chiudere scansione 15 min prima della partenza\n\u2022 Riconciliare no-show\n\u2022 Bags off per no-show (sicurezza)\n\u2022 Trasmettere DEP (Departure Message)\n\u2022 Comunicare via radio/telefono al supervisore operativo'}]}]},{id:'vueling',name:'Vueling',code:'VY',color:'#F7C800',textColor:'#1a1a1a',sections:[{title:'Check-in Amadeus Alt\xe9a',items:[{title:'Apertura volo',body:'DCS Vueling \u2013 Amadeus Alt\xe9a DCS:\n\nLogin \u2192 selezionare volo \u2192 verificare rotta e data \u2192 aprire check-in.\n\nVerificare eventuali restrizioni operative sul volo.'},{title:'Tariffe e bagagli',body:'Tariffa Basic:\n\u2022 1 borsa 40\xd720\xd730 cm (gratis, sotto sedile)\n\nTariffa Optima / TimeFlex:\n\u2022 Bagaglio cabina 55\xd735\xd725 cm incluso\n\u2022 Possibile bagaglio stiva incluso\n\nVerificare sempre la tariffa nella prenotazione.'},{title:'Documenti e TIMATIC',body:'Consultare TIMATIC in Alt\xe9a per requisiti documenti.\n\nVoli intra-UE: carta d\'identit\xe0 o passaporto.\nVoli extra-UE: passaporto + eventuale visto.\n\nVerificare validit\xe0 documento rispetto alla data di rientro.'}]},{title:'Imbarco',items:[{title:'Sequenza imbarco',body:'Ordine imbarco Vueling:\n1. Passeggeri speciali\n2. Vueling Club Platinum / Gold\n3. Biglietti Excellence\n4. Tutti gli altri\n\nAnnuncio imbarco via interfono o display gate.'},{title:'Chiusura e APIS',body:'Chiusura volo:\n1. Scansione passeggeri completata\n2. Riconciliare no-show in Alt\xe9a\n3. Trasmissione APIS se rotta lo richiede\n4. Load sheet definitiva approvata\n5. Chiusura volo nel sistema'}]}]}],b=/(`[^`]+`)/g;function x(e){var t=e.text,i=e.colors,o=t.split(b);return(0,s.jsx)(a.Text,{style:{fontSize:13,color:i.textSub,lineHeight:20},children:o.map((e,t)=>{if(e.startsWith('`')&&e.endsWith('`')){var i=e.slice(1,-1);return(0,s.jsx)(a.Text,{style:{fontFamily:'monospace',fontSize:12,fontWeight:'700',color:'#93C5FD',backgroundColor:'#1E3A5F',paddingHorizontal:5,borderRadius:4},children:i},t)}return(0,s.jsx)(a.Text,{children:e},t)})})}function h(e){var o=e.commands,l=e.colors,c=(0,i.useState)(''),u=(0,t.default)(c,2),p=u[0],b=u[1],x=p.toLowerCase(),h=x?o.filter(e=>e.cmd.toLowerCase().includes(x)||e.desc.toLowerCase().includes(x)):o,f=[...new Set(h.map(e=>e.category))];return(0,s.jsxs)(a.View,{style:{flex:1},children:[(0,s.jsxs)(a.View,{style:{backgroundColor:l.card,borderRadius:8,marginBottom:12,borderWidth:1,borderColor:l.border,flexDirection:'row',align